# ─────────────────────────────────────────────────────────────────────────────
# linkage-engine — local development environment variables
# Copy this file to .env and fill in your values.
# .env is git-ignored; .env.example is committed.
# ─────────────────────────────────────────────────────────────────────────────

# ── PostgreSQL ────────────────────────────────────────────────────────────────
# Local Docker (see README quick start):
DB_URL=jdbc:postgresql://localhost:5434/linkage_db
DB_USER=ancestry
DB_PASSWORD=password

# ── AWS (required only for Bedrock LLM / embeddings) ─────────────────────────
AWS_REGION=us-east-1

# Bedrock Converse — chat / semantic summary
# Set LINKAGE_SEMANTIC_LLM_ENABLED=false to skip LLM calls entirely (local profile default)
BEDROCK_MODEL_ID=us.amazon.nova-lite-v1:0
LINKAGE_SEMANTIC_LLM_ENABLED=false

# Bedrock Titan — embeddings + vector rerank + reindex
# Leave unset (or set to anything other than bedrock-titan) to disable embedding
# SPRING_AI_MODEL_EMBEDDING=bedrock-titan
# BEDROCK_EMBEDDING_MODEL_ID=amazon.titan-embed-text-v2:0

# ── S3 landing zone (optional — for batch ingest tooling) ────────────────────
# LINKAGE_S3_BUCKET=your-org-linkage-landing
# LINKAGE_S3_PREFIX=landing/
# AWS_ENDPOINT_URL=http://localhost:9000   # MinIO / LocalStack only

# ── Demo HTTP clients (optional — seed-data.sh, demo-calls.sh) ────────────────
# Default is http://localhost:8080. Point at an ALB or tunnel when seeding remote:
# BASE_URL=http://linkage-engine-alb-....elb.amazonaws.com
# (LINKAGE_BASE_URL is an alias — seed scripts accept either.)
# LINKAGE_BASE_URL=http://localhost:8080
#
# ECS / secured ingest: POST /v1/records requires X-Api-Key when the task sets INGEST_API_KEY.
# Match the value from Secrets Manager (same as the linkage-engine/runtime secret).
# INGEST_API_KEY=
