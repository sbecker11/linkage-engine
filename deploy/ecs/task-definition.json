{
  "family": "linkage-engine",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "1024",
  "memory": "2048",
  "executionRoleArn": "arn:aws:iam::286103606369:role/linkage-engine-execution-role",
  "taskRoleArn": "arn:aws:iam::286103606369:role/linkage-engine-task-role",
  "containerDefinitions": [
    {
      "name": "linkage-engine",
      "image": "286103606369.dkr.ecr.us-west-1.amazonaws.com/linkage-engine:latest",
      "essential": true,
      "portMappings": [
        { "containerPort": 8080, "hostPort": 8080, "protocol": "tcp" }
      ],
      "environment": [
        { "name": "AWS_REGION",                   "value": "us-west-1" },
        { "name": "SPRING_PROFILES_ACTIVE",        "value": "bedrock" },
        { "name": "BEDROCK_MODEL_ID",              "value": "us.amazon.nova-lite-v1:0" },
        { "name": "SPRING_AI_MODEL_EMBEDDING",     "value": "bedrock-titan" },
        { "name": "BEDROCK_EMBEDDING_MODEL_ID",    "value": "amazon.titan-embed-text-v2:0" },
        { "name": "LINKAGE_SEMANTIC_LLM_ENABLED",  "value": "true" },
        { "name": "LINKAGE_COST_ENABLED",         "value": "true" },
        { "name": "LINKAGE_COST_TAG_KEY",           "value": "App" },
        { "name": "LINKAGE_COST_TAG_VALUE",         "value": "linkage-engine" }
      ],
      "secrets": [
        { "name": "DB_URL",         "valueFrom": "arn:aws:secretsmanager:us-west-1:286103606369:secret:linkage-engine/runtime-qUeNUn:DB_URL::" },
        { "name": "DB_USER",        "valueFrom": "arn:aws:secretsmanager:us-west-1:286103606369:secret:linkage-engine/runtime-qUeNUn:DB_USER::" },
        { "name": "DB_PASSWORD",    "valueFrom": "arn:aws:secretsmanager:us-west-1:286103606369:secret:linkage-engine/runtime-qUeNUn:DB_PASSWORD::" },
        { "name": "INGEST_API_KEY", "valueFrom": "arn:aws:secretsmanager:us-west-1:286103606369:secret:linkage-engine/runtime-qUeNUn:INGEST_API_KEY::" }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/linkage-engine",
          "awslogs-region": "us-west-1",
          "awslogs-stream-prefix": "ecs"
        }
      }
    }
  ]
}
