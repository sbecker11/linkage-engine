{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "LinkageEngineReadRuntimeSecret",
      "Effect": "Allow",
      "Action": [
        "secretsmanager:GetSecretValue"
      ],
      "Resource": [
        "arn:aws:secretsmanager:us-west-1:286103606369:secret:linkage-engine/*"
      ]
    },
    {
      "Sid": "LinkageEngineDecryptRuntimeSecretKms",
      "Effect": "Allow",
      "Action": [
        "kms:Decrypt"
      ],
      "Resource": "*",
      "Condition": {
        "StringEquals": {
          "kms:ViaService": [
            "secretsmanager.us-west-1.amazonaws.com"
          ]
        }
      }
    }
  ]
}
